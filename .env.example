# =============================================================
# BQ Viewer — Environment Variables
# Copy this file to .env and adjust for your setup
# =============================================================

# ---- Server ----
PORT=5000
NODE_ENV=production

# ---- MongoDB (wajib diisi) ----
# Gunakan MongoDB server Anda sendiri (Atlas / self-hosted / dsb)
# Contoh:
#   mongodb://username:password@host:27017/bq_viewer_db?directConnection=true
#   mongodb+srv://username:password@cluster.mongodb.net/bq_viewer_db
MONGODB_URI=mongodb://root:password@your-mongo-host:27017/bq_viewer_db?directConnection=true

# ---- Enkripsi (wajib diisi) ----
# Generate dengan: openssl rand -base64 64
# Atau: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
ENCRYPTION_KEY=generate-a-random-64-byte-base64-key-here

# ---- Autentikasi ----
# Username dan password untuk login.
# Default user akan di-seed otomatis ke database saat pertama kali aplikasi berjalan.
# AUTH_PASSWORD bisa berupa plain text (akan di-hash otomatis oleh aplikasi).
AUTH_USERNAME=admin
AUTH_PASSWORD=your-password-here

# ---- Google BigQuery ----
# Credentials GCP disimpan di MongoDB melalui fitur Connections di UI.
# Tidak perlu file JSON service account atau GOOGLE_APPLICATION_CREDENTIALS.

# ---- CORS (optional) ----
# Comma-separated list of allowed origins (tanpa spasi setelah koma)
# Berguna saat deploy ke Coolify dengan domain kustom
# Contoh: CORS_ORIGIN=http://localhost:5173,http://localhost,https://bq-viewer.domain.com
# CORS_ORIGIN=
