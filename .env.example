# =============================================================
# BQ Viewer — Environment Variables
# Copy this file to .env and adjust for your setup
# =============================================================

# ---- Server ----
PORT=5000
NODE_ENV=production

# ---- MongoDB ----
MONGODB_URI=mongodb://root:password@localhost:27017/bq_viewer_db?directConnection=true

# ---- Google BigQuery ----
# Path to service account key file inside the container
# Mount the JSON file as a volume at this path
GOOGLE_APPLICATION_CREDENTIALS=/app/config/gcp-service-account.json

# ---- CORS (optional) ----
# Comma-separated list of allowed origins
# CORS_ORIGIN=http://localhost:5173,http://localhost
