# =============================================================================
# BQ Viewer — Docker Compose Environment Variables
# Copy file ini ke .env (di folder yang sama dengan docker-compose.yml)
# =============================================================================

# ---- Docker Hub ----
# Username Docker Hub tempat image be-bq-viewer & fe-bq-viewer di-push
DOCKER_USERNAME=your-dockerhub-username

# ---- Ports (opsional) ----
BACKEND_PORT=5000
FRONTEND_PORT=80

# ---- MongoDB (wajib diisi) ----
# Gunakan MongoDB server yang sudah ada (tidak dibuat ulang oleh compose ini)
MONGODB_URI=mongodb://username:password@your-mongo-host:27017/bq_viewer_db?directConnection=true

# ---- Enkripsi (wajib diisi) ----
# Generate dengan: openssl rand -base64 64
ENCRYPTION_KEY=generate-a-random-64-byte-base64-key-here

# ---- Autentikasi (wajib diisi) ----
# Bcrypt hash dari password login.
# Generate: node -e "require('bcryptjs').hash('password-anda', 15).then(console.log)"
AUTH_PASSWORD=$2a$15$YourBcryptHashHere

# ---- CORS (opsional) ----
# Comma-separated list of allowed origins
# CORS_ORIGIN=http://localhost,https://bq-viewer.domain.com
